{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PPP Flow Desktop",
  "version": "0.1.0-beta.4",
  "identifier": "com.jwaterslynch.pppflow",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PPP Flow Desktop",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https: http://127.0.0.1:11434 http://localhost:11434"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "iOS": {
      "developmentTeam": "9G55P259N7",
      "minimumSystemVersion": "14.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
